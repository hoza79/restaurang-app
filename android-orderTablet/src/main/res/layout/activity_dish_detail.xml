<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDetailDishName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#EEEEEE"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvDetailPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#C9A961"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvCookingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tillagning"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#EEEEEE"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgCooking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <RadioButton
                android:id="@+id/rbRare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rare"
                android:textColor="#EEEEEE"
                android:textSize="14sp"/>
            <RadioButton
                android:id="@+id/rbMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:textColor="#EEEEEE"
                android:textSize="14sp"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/rbWellDone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Well done"
                android:textColor="#EEEEEE"
                android:textSize="14sp"/>
        </RadioGroup>

        <TextView
            android:id="@+id/tvSidesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sidorätter"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#EEEEEE"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/llSides"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvSaucesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sås"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#EEEEEE"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/llSauces"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvCommentLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kommentar till köket"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#EEEEEE"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etComment"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="T.ex. utan lök, extra sås..."
            android:background="#1E1E1E"
            android:textColor="#EEEEEE"
            android:textColorHint="#888888"
            android:padding="12dp"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnAddToOrder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Lägg till i beställning"
            android:backgroundTint="#C9A961"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>