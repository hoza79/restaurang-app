<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#0D0D0D"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Antons Skafferi"
            android:textColor="#EEEEEE"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnKitchenView"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="🍳 KÖK"
            android:backgroundTint="#C9A961"
            android:textColor="#1A1A1A"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginEnd="14dp"/>

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#C9A961"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VÄLJ BORD"
        android:textSize="11sp"
        android:textColor="#666666"
        android:letterSpacing="0.15"
        android:padding="16dp"/>

    <GridLayout
        android:id="@+id/tableGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="5"
        android:padding="8dp"
        android:rowCount="2"/>

    <!-- Legend -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <View android:layout_width="12dp" android:layout_height="12dp"
            android:background="#252525" android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Ledig" android:textSize="12sp" android:textColor="#888888"
            android:layout_marginEnd="16dp"/>

        <View android:layout_width="12dp" android:layout_height="12dp"
            android:background="#2A1A0E" android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Upptaget" android:textSize="12sp" android:textColor="#888888"
            android:layout_marginEnd="16dp"/>

        <View android:layout_width="12dp" android:layout_height="12dp"
            android:background="#3D2E00" android:layout_marginEnd="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Öppen nota" android:textSize="12sp" android:textColor="#888888"/>
    </LinearLayout>

</LinearLayout>