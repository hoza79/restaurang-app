<?xml version="1.0" encoding="utf-8"?>
<!--
  ETT KORT = ETT BORD.
  Hela kortet är klickbart. Inga knappar. Minimalt brus.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/orderCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#252525"
    android:layout_margin="10dp"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Rubrikrad: Bord X  |  kurs  |  tid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#1E1E1E"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvTableNum"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvCourseBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#C9A961"
            android:textSize="13sp"
            android:layout_marginEnd="12dp"/>

        <!-- Tidsbadge – bakgrundsfärg sätts i kod -->
        <TextView
            android:id="@+id/tvTimeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#1A1A1A"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>
    </LinearLayout>

    <!-- Rätterlista -->
    <LinearLayout
        android:id="@+id/llDishList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"/>

    <!-- Hint längst ned -->
    <TextView
        android:id="@+id/tvTapHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tryck för att markera som KLAR"
        android:textColor="#555555"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingBottom="10dp"/>

</LinearLayout>